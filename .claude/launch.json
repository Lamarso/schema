{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "schema",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs');const path=require('path');let p=req.url.split('?')[0];if(p==='/')p='/index.html';const full=path.join(__dirname,p);fs.readFile(full,(err,data)=>{if(err){res.writeHead(404);res.end('not found');return;}res.writeHead(200);res.end(data);});}).listen(8123,()=>console.log('listening on 8123'));"],
      "port": 8123
    }
  ]
}
